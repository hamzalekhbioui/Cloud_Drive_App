# Backend runtime env vars
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<rotated-key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=files

DB_URL=jdbc:postgresql://localhost:5432/clouddrive
DB_USERNAME=postgres
DB_PASSWORD=change_me

JWT_SECRET=replace_with_a_long_random_secret_value_at_least_32_chars
JWT_EXPIRATION_MS=86400000
SERVER_PORT=8081

